// ── CONTROLLO STALLO ────────────────────────────────────
function checkStalemate() {
  const nextColor = queue[0];
  const reserveColor = reserve;

  // Se il prossimo è un power up, sempre giocabile
  if (nextColor === 'witch' || nextColor === 'bomber') return;

  // Colori disponibili da piazzare (coda + riserva se non è power up)
  const available = new Set([nextColor]);
  if (reserveColor && reserveColor !== 'witch' && reserveColor !== 'bomber') available.add(reserveColor);

  // Controlla se esiste almeno una cella libera con colore diverso dai disponibili
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++) {
      const d = grid[r][c];
      if (!d.spider && !d.web && !d.black && !d.bomb && !d.empty) {
        if (!available.has(d.color)) return; // esiste una mossa valida
      }
    }

  // Nessuna mossa valida → game over
  triggerGameOver();
}

function triggerGameOver() {
  gameOver = true;
  el('go-score').textContent = 'Punteggio finale: ' + score;
  el('gameover').classList.add('show');
}

// ═══════════════════════════════════════════════════════
// INPUT
// ═══════════════════════════════════════════════════════
function onCellClick(e) {
  if (gameOver || busy) return;
  const r = +e.currentTarget.dataset.r;
  const c = +e.currentTarget.dataset.c;
  const d = grid[r][c];

  // Celle bloccate
  if (d.spider || d.web || d.black || d.empty) return;

  busy = true;

  // Tap su bomba → esplodi
  if (d.bomb) {
    tapCount++;
    if (tapCount % SPIDER_EVERY === 0) needSpawn = true;
    renderCountdown();
    explodeBomb(r, c);
    scheduleMoveSpiders();
    return;
  }

  // Non mettere stesso colore su stesso colore
  const color = queue[0];
  if (color !== 'witch' && color !== 'bomber' && d.color === color) { busy = false; return; }

  // Incrementa tapCount per witch e bomber
  if (color === 'witch' || color === 'bomber') {
    tapCount++;
    if (tapCount % SPIDER_EVERY === 0) needSpawn = true;
    renderCountdown();
  }

  // MAGA: elimina tutti i funghi del colore tappato
  if (color === 'witch') {
    const targetColor = d.color;
    queue.shift(); queue.push(rndToken());
    renderQueue();

    const witchDom = cellEl(r, c);
    if (witchDom) {
      witchDom.innerHTML = '';
      witchDom.style.background  = 'transparent';
      witchDom.style.borderColor = 'transparent';
      const wm = document.createElement('div');
      wm.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center;background-size:95%;pointer-events:none;z-index:10;';
      wm.style.backgroundImage = `url(${WITCH_IMG})`;
      witchDom.appendChild(wm);
    }

    const toMatch = new Set();
    for (let r2 = 0; r2 < ROWS; r2++)
      for (let c2 = 0; c2 < COLS; c2++)
        if (grid[r2][c2].color === targetColor && !grid[r2][c2].black && !grid[r2][c2].bomb)
          toMatch.add(r2 + ',' + c2);

    toMatch.forEach(key => {
      const [r2, c2] = key.split(',').map(Number);
      const dom2 = cellEl(r2, c2);
      if (dom2) {
        const col = COLORS[targetColor];
        dom2.style.setProperty('--glow-color', col.bg);
        dom2.classList.add('glowing');
        const m = dom2.querySelector('.mushroom');
        if (m) m.classList.add('anim-pulse');
      }
    });

    score += toMatch.size * 10;
    el('score-val').textContent = score;
    feedback('✨ Magia! +' + toMatch.size * 10, '#ffd700', 2000);

    cascading++;
    setTimeout(() => {
      toMatch.forEach(key => {
        const [r2, c2] = key.split(',').map(Number);
        animate(r2, c2, 'anim-match', ANIM_MS);
      });
      setTimeout(() => {
        toMatch.forEach(key => {
          const [r2, c2] = key.split(',').map(Number);
          addPowerCharge(targetColor, 1);
          grid[r2][c2].spider = 0; grid[r2][c2].spiderId = 0; grid[r2][c2].web = false;
          grid[r2][c2] = mkCell();
          const dom2 = cellEl(r2, c2);
          if (dom2) dom2.dataset.spawn = '1';
          renderCell(r2, c2);
        });
        renderCell(r, c);
        cascading--;
        scheduleMoveSpiders();
        setTimeout(resolveBoard, CASCADE_MS);
      }, ANIM_MS);
    }, 950);

    renderCountdown();
    return;
  }

  // BOMBER: esplode 3x3 centrato sulla cella tappata
  if (color === 'bomber') {
    queue.shift(); queue.push(rndToken());
    renderQueue();

    // Mostra il vecchio sulla cella per un momento
    const bombDom = cellEl(r, c);
    if (bombDom) {
      bombDom.innerHTML = '';
      bombDom.style.background  = 'transparent';
      bombDom.style.borderColor = 'transparent';
      const bm = document.createElement('div');
      bm.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center;background-size:95%;pointer-events:none;z-index:10;';
      bm.style.backgroundImage = `url(${BOMBER_IMG})`;
      bombDom.appendChild(bm);
    }

    // Calcola celle 3x3 (escludi celle empty permanenti)
    const toExplode = new Set();
    for (let dr = -1; dr <= 1; dr++)
      for (let dc = -1; dc <= 1; dc++) {
        const r2 = r + dr, c2 = c + dc;
        if (r2 >= 0 && r2 < ROWS && c2 >= 0 && c2 < COLS && !grid[r2][c2].empty)
          toExplode.add(r2 + ',' + c2);
      }

    // Illumina le celle coinvolte con glow arancione
    toExplode.forEach(key => {
      const [r2, c2] = key.split(',').map(Number);
      const dom2 = cellEl(r2, c2);
      if (dom2) {
        dom2.style.setProperty('--glow-color', '#ff6b00');
        dom2.classList.add('glowing');
      }
    });

    feedback('💥 Boom! +' + toExplode.size * 10, '#ff6b00', 1500);

    // Dopo il glow (0.9s) → esplodi
    setTimeout(() => {
      toExplode.forEach(key => {
        const [r2, c2] = key.split(',').map(Number);
        animate(r2, c2, 'anim-explode', ANIM_MS);
      });

      // Trova bombe a catena nel 3x3 PRIMA di sovrascrivere
      const chainBombs = [];
      toExplode.forEach(key => {
        const [r2, c2] = key.split(',').map(Number);
        if (grid[r2][c2].bomb) chainBombs.push({r: r2, c: c2, bomb: grid[r2][c2].bomb});
      });

      score += toExplode.size * 10;
      el('score-val').textContent = score;
      if (chainBombs.length) feedback('💥 Catena!', '#ff6b00', 1500);

      cascading++;
      setTimeout(() => {
        toExplode.forEach(key => {
          const [r2, c2] = key.split(',').map(Number);
          
          const elimColor = grid[r2][c2].color;
          if (elimColor) addPowerCharge(elimColor, 1);
          grid[r2][c2].spider = 0; grid[r2][c2].spiderId = 0;
          grid[r2][c2].web = false; grid[r2][c2].black = false;
          grid[r2][c2] = mkCell();
          const dom2 = cellEl(r2, c2);
          if (dom2) dom2.dataset.spawn = '1';
          renderCell(r2, c2);
        });
        // Esplodi bombe a catena — ripristina tipo bomba prima di esplodere
        chainBombs.forEach(({r: r2, c: c2, bomb}) => {
          grid[r2][c2].bomb = bomb;
          explodeBomb(r2, c2);
        });
        cascading--;
        scheduleMoveSpiders();
        setTimeout(resolveBoard, CASCADE_MS);
      }, ANIM_MS);
    }, 950);

    renderCountdown();
    return;
  }

  // Piazza colore
  grid[r][c] = mkCell(color);
  queue.shift();
  queue.push(rndToken());
  renderCell(r, c);
  animate(r, c, 'anim-spawn', ANIM_MS);
  renderQueue();

  // Ogni tap incrementa il contatore → ragno ogni SPIDER_EVERY
  tapCount++;
  if (tapCount % SPIDER_EVERY === 0) needSpawn = true;
  renderCountdown();

  // Controlla match PRIMA — se il bruco è incluso nel match viene eliminato
  const matches = findMatches();
  const result  = applyMatches(matches, r, c);

  // Dopo i match: il bruco mangia se non è stato eliminato

  checkStalemate();

  if (result === false) {
    moveSpiders();
    if (needSpawn) { needSpawn = false; spawnSpider(); }
    busy = false;
  } else {
    scheduleMoveSpiders();
  }
}

el('reserve').addEventListener('click', () => {
  if (gameOver || busy) return;
  const cur = queue[0];
  if (!reserve) {
    reserve = cur;
    queue.shift();
    queue.push(rndToken());
  } else {
    [reserve, queue[0]] = [queue[0], reserve];
  }
  renderReserve();
  renderQueue();
});

// ═══════════════════════════════════════════════════════
// AUDIO
// ═══════════════════════════════════════════════════════
let audioCtx = null;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

function playTone({ freq = 440, freq2 = null, type = 'sine', attack = 0.01, decay = 0.15, vol = 0.3, vibrato = 0, detune = 0 }) {
  try {
    const ctx = getAudioCtx();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);

    osc.type = type;
    osc.frequency.setValueAtTime(freq, ctx.currentTime);
    if (freq2) osc.frequency.linearRampToValueAtTime(freq2, ctx.currentTime + decay);
    if (detune) osc.detune.setValueAtTime(detune, ctx.currentTime);

    // Vibrato
    if (vibrato > 0) {
      const lfo = ctx.createOscillator();
      const lfoGain = ctx.createGain();
      lfo.frequency.setValueAtTime(vibrato, ctx.currentTime);
      lfoGain.gain.setValueAtTime(15, ctx.currentTime);
      lfo.connect(lfoGain);
      lfoGain.connect(osc.frequency);
      lfo.start();
      lfo.stop(ctx.currentTime + decay + 0.1);
    }

    gain.gain.setValueAtTime(0, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(vol, ctx.currentTime + attack);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + attack + decay);

    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + attack + decay + 0.05);
  } catch(e) {}
}

function playMatchSound(color) {
  switch(color) {
    case 'red':
      // Allegro e vivace — due note veloci verso l'alto
      playTone({ freq: 523, freq2: 784, type: 'square', decay: 0.12, vol: 0.25 });
      setTimeout(() => playTone({ freq: 784, freq2: 1047, type: 'square', decay: 0.1, vol: 0.2 }), 80);
      break;
    case 'yellow':
      // Timido e sottile — nota alta e breve, quasi un sussurro
      playTone({ freq: 1047, type: 'sine', attack: 0.05, decay: 0.2, vol: 0.15, vibrato: 6 });
      break;
    case 'blue':
      // Basso e burbero — nota grave e corta
      playTone({ freq: 130, freq2: 98, type: 'sawtooth', decay: 0.2, vol: 0.3 });
      setTimeout(() => playTone({ freq: 110, type: 'square', decay: 0.1, vol: 0.15 }), 60);
      break;
    case 'green':
      // Sorpreso — salto di ottava improvviso
      playTone({ freq: 330, freq2: 880, type: 'sine', attack: 0.005, decay: 0.18, vol: 0.25 });
      break;
    case 'orange':
      // Furbo e veloce — tripletta discendente
      playTone({ freq: 880, type: 'triangle', decay: 0.08, vol: 0.2 });
      setTimeout(() => playTone({ freq: 698, type: 'triangle', decay: 0.08, vol: 0.2 }), 70);
      setTimeout(() => playTone({ freq: 587, type: 'triangle', decay: 0.1, vol: 0.2 }), 140);
      break;
    case 'purple':
      // Elegante — nota lunga con vibrato, quasi operistica
      playTone({ freq: 659, type: 'sine', attack: 0.08, decay: 0.5, vol: 0.2, vibrato: 5 });
      setTimeout(() => playTone({ freq: 523, type: 'sine', attack: 0.05, decay: 0.4, vol: 0.12, vibrato: 4 }), 150);
      break;
  }
}

function playBombSound(type) {
  // Esplosione — rumore + discesa
  playTone({ freq: 200, freq2: 50, type: 'sawtooth', decay: 0.3, vol: 0.4 });
  setTimeout(() => playTone({ freq: 150, freq2: 40, type: 'square', decay: 0.25, vol: 0.3 }), 60);
}

function playSpawnSound() {
  playTone({ freq: 220, freq2: 440, type: 'sine', attack: 0.005, decay: 0.08, vol: 0.1 });
}

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
function buildDOM() {
  const g = el('grid');
  g.innerHTML = '';
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++) {
      const div = document.createElement('div');
      div.className = 'cell';
      div.dataset.r = r;
      div.dataset.c = c;
      div.addEventListener('click', onCellClick);
      g.appendChild(div);
    }
}

function newGame() {
  gameOver       = false;
  busy           = false;
  cascading      = 0;
  needSpiderMove = false;
  needSpawn      = false;
  spiderSeq      = 0;
  score          = 0;
  tapCount       = 0;
  reserve        = null;

  el('score-val').textContent = 0;
  el('feedback').textContent  = '';
  el('gameover').classList.remove('show');

  grid = Array.from({length: ROWS}, () =>
    Array.from({length: COLS}, () => mkCell())
  );
  queue = [rndToken(), rndToken(), rndToken()];

  powerCharge = { red:0, yellow:0, blue:0, green:0, orange:0, purple:0 };
  buildPowerBarsDOM();
  buildDOM();
  renderAllCells();
  renderQueue();
  renderReserve();
  renderCountdown();

  // Risolvi match iniziali
  setTimeout(resolveBoard, 150);
}

el('btn-new').addEventListener('click', newGame);
el('go-btn').addEventListener('click', newGame);

newGame();
