<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Shroomatch</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background-color: #1a1a2e;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px;
    gap: 12px;
    font-family: 'Segoe UI', sans-serif;
    color: #fff;
    user-select: none;
  }

  h1 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 3px;
    color: #e0d7ff;
    margin-top: 4px;
  }

  #score-bar { font-size: 15px; color: #888; }
  #score-bar span { color: #fff; font-weight: 600; }

    /* ── POWER BARS ── */
  #power-bars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5px;
    width: min(348px, 92vw);
  }
  .power-bar { display: flex; flex-direction: column; gap: 3px; }
  .power-bar-track {
    height: 8px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .power-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.3s ease;
    width: 0%;
  }
  .power-bar-label {
    font-size: 9px;
    color: #666;
    text-align: center;
    letter-spacing: 0.3px;
  }
  .power-bar.ready .power-bar-fill { animation: power-pulse 0.6s ease-in-out infinite alternate; }
  .power-bar.ready .power-bar-label { color: #fff; font-weight: 700; }
  @keyframes power-pulse { 0%{filter:brightness(1)} 100%{filter:brightness(2)} }

  @keyframes power-flash {
    0%   { background: var(--flash-color); transform: scale(1); }
    30%  { background: var(--flash-color); transform: scale(1.15); filter: brightness(2); }
    60%  { background: var(--flash-color); transform: scale(0.95); filter: brightness(1.5); }
    100% { background: var(--flash-color); transform: scale(1); filter: brightness(1); }
  }
  .cell.power-flashing {
    animation: power-flash 0.35s ease-in-out forwards;
    z-index: 5;
  }

  #grid {
    background-image: url('data:image/jpeg;base64,');
    background-repeat: repeat;
    background-size: 300px 300px;
    border-radius: 12px;
    padding: 5px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 5px;
    width: min(348px, 92vw);
  }

  .cell {
    aspect-ratio: 1;
    border-radius: 9px;
    border: 2px solid rgba(255,255,255,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    position: relative;
    transition: transform 0.08s;
    -webkit-tap-highlight-color: transparent;
    overflow: hidden;
  }
  .cell:active           { transform: scale(0.88); }
  .cell.blocked          { cursor: not-allowed; }
  .cell.blocked:active   { transform: none; }

  .cell.anim-match  { animation: anim-match  0.20s ease forwards; }
  .cell.anim-explode{ animation: anim-explode 0.20s ease forwards; }

  @keyframes anim-match   { 0%{transform:scale(1)} 50%{transform:scale(1.3);filter:brightness(1.7)} 100%{transform:scale(1);filter:none} }
  @keyframes anim-explode { 0%{transform:scale(1)} 50%{transform:scale(1.4);filter:brightness(2)} 100%{transform:scale(1);filter:none} }
  @keyframes anim-pulse {
    0%   { transform: scale(1);    filter: brightness(1); }
    25%  { transform: scale(1.2);  filter: brightness(2) saturate(3); }
    50%  { transform: scale(0.95); filter: brightness(1.2); }
    75%  { transform: scale(1.15); filter: brightness(2.5) saturate(4); }
    100% { transform: scale(1);    filter: brightness(1); }
  }
  @keyframes cell-glow {
    0%   { box-shadow: inset 0 0 0px 0px rgba(255,255,255,0); }
    25%  { box-shadow: inset 0 0 20px 8px var(--glow-color); }
    50%  { box-shadow: inset 0 0 8px 2px var(--glow-color); }
    75%  { box-shadow: inset 0 0 24px 10px var(--glow-color); }
    100% { box-shadow: inset 0 0 0px 0px rgba(255,255,255,0); }
  }
  .cell.glowing {
    animation: cell-glow 0.3s ease-in-out 3 forwards;
  }
  .cell .mushroom.anim-pulse {
    animation: anim-pulse 0.3s ease-in-out 3 forwards !important;
  }

  .cell.anim-match   .mushroom { animation: anim-match   0.20s ease forwards !important; }
  .cell.anim-explode .mushroom { animation: anim-explode 0.20s ease forwards !important; }

  /* Layer immagine fungo — div interno */
  .cell .mushroom {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    background-position: center 55%;
    background-size: 90%;
    pointer-events: none;
    transform-origin: bottom center;
  }

  @keyframes mushroom-spawn {
    0%   { transform: scale(0);    opacity: 0; }
    50%  { transform: scale(1.25); opacity: 1; }
    75%  { transform: scale(0.9);  }
    100% { transform: scale(1);    }
  }
  .cell .mushroom.spawning {
    animation: mushroom-spawn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes idle-bounce {
    0%   { transform: skewX(0deg); }
    25%  { transform: skewX(6deg); }
    75%  { transform: skewX(-6deg); }
    100% { transform: skewX(0deg); }
  }
  @keyframes idle-bounce-yellow {
    0%   { transform: skewX(0deg); }
    25%  { transform: skewX(8deg); }
    75%  { transform: skewX(-8deg); }
    100% { transform: skewX(0deg); }
  }
  @keyframes idle-bounce-blue {
    0%   { transform: skewX(0deg); }
    25%  { transform: skewX(5deg); }
    75%  { transform: skewX(-5deg); }
    100% { transform: skewX(0deg); }
  }
  @keyframes shiver {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(-2px) rotate(-1deg); }
    40%  { transform: translateX(2px) rotate(1deg); }
    60%  { transform: translateX(-2px) rotate(-1deg); }
    80%  { transform: translateX(2px) rotate(1deg); }
    100% { transform: translateX(0); }
  }
  .cell .mushroom.scared {
    animation: shiver 0.3s ease-in-out infinite !important;
    transform-origin: bottom center;
  }
  .cell .mushroom.idle-red    { animation: idle-bounce        1.4s ease-in-out infinite; }
  .cell .mushroom.idle-yellow { animation: idle-bounce-yellow 1.8s ease-in-out infinite; background-position: center 85%; background-size: 110%; }
  .cell .mushroom.idle-blue   { animation: idle-bounce-blue   1.1s ease-in-out infinite; }
  .cell .mushroom.idle-green  { animation: idle-bounce        1.6s ease-in-out infinite; }
  .cell .mushroom.idle-orange { animation: idle-bounce        1.3s ease-in-out infinite; }
  .cell .mushroom.idle-purple { animation: idle-bounce        2.2s ease-in-out infinite; }

  /* ── CONTROLLI ── */
  #controls {
    display: flex;
    align-items: center;
    gap: 8px;
    width: min(348px, 92vw);
  }

  .ctrl-label {
    font-size: 9px;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-align: center;
    margin-bottom: 3px;
  }

  /* Riserva */
  #reserve-wrap { display: flex; flex-direction: column; align-items: center; }
  #reserve {
    width: 50px; height: 50px;
    border-radius: 9px;
    border: 2px dashed #444;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; color: #555;
    cursor: pointer;
    background: #111;
    transition: transform 0.08s;
    -webkit-tap-highlight-color: transparent;
    position: relative;
    overflow: hidden;
  }
  #reserve.filled { border-style: solid; border-color: rgba(255,255,255,0.2); }
  #reserve:active { transform: scale(0.9); }

  /* Coda */
  #queue-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; }
  #queue { display: flex; gap: 5px; align-items: center; }
  .q-item {
    border-radius: 7px;
    border: 2px solid rgba(255,255,255,0.12);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }
  .q-item:nth-child(1) { width: 50px; height: 50px; border-color: rgba(255,255,255,0.35); }
  .q-item:nth-child(2) { width: 38px; height: 38px; opacity: 0.7; }
  .q-item:nth-child(3) { width: 30px; height: 30px; opacity: 0.45; }

  /* Pallini */
  #dots-wrap { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  #spider-countdown {
    font-size: 22px; font-weight: 700; color: #e74c3c;
    line-height: 1; min-width: 28px; text-align: center;
    transition: transform 0.15s;
  }
  #spider-countdown.pulse { animation: spider-pulse 0.3s ease; }
  @keyframes spider-pulse { 0%{transform:scale(1)} 50%{transform:scale(1.4)} 100%{transform:scale(1)} }

  /* Feedback */
  #feedback {
    font-size: 13px;
    color: #888;
    min-height: 16px;
    text-align: center;
    letter-spacing: 0.3px;
  }

  /* Pulsante */
  #btn-new {
    padding: 7px 18px;
    border: 1.5px solid #444;
    border-radius: 7px;
    background: transparent;
    color: #aaa;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: border-color 0.15s, color 0.15s;
  }
  #btn-new:hover  { border-color: #888; color: #fff; }
  #btn-new:active { transform: scale(0.96); }

  /* Game Over */
  #gameover {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.78);
    flex-direction: column;
    align-items: center; justify-content: center;
    gap: 14px;
    z-index: 99;
  }
  #gameover.show { display: flex; }
  #gameover h2   { font-size: 30px; color: #e74c3c; letter-spacing: 3px; }
  #gameover p    { font-size: 15px; color: #ccc; }
  #gameover button {
    padding: 10px 26px;
    background: #e74c3c; border: none; border-radius: 8px;
    color: #fff; font-size: 14px; cursor: pointer; font-family: inherit;
  }
</style>
</head>
<body>

<h1>🍄 SHROOMATCH</h1>
<div id="score-bar">Punteggio: <span id="score-val">0</span></div>

<div id="power-bars"></div>

<div id="grid"></div>

<div id="controls">
  <div id="reserve-wrap">
    <div class="ctrl-label">Riserva</div>
    <div id="reserve">vuota</div>
  </div>
  <div id="queue-wrap">
    <div class="ctrl-label">Prossimi</div>
    <div id="queue">
      <div class="q-item" id="q0"></div>
      <div class="q-item" id="q1"></div>
      <div class="q-item" id="q2"></div>
    </div>
  </div>
  <div id="dots-wrap">
    <div class="ctrl-label">Ragno tra</div>
    <div id="spider-countdown">2</div>
  </div>
</div>

<div id="feedback"></div>
<button id="btn-new">↺ Nuova partita</button>

<div id="gameover">
  <h2>GAME OVER</h2>
  <p id="go-score"></p>
  <button id="go-btn">Rigioca</button>
</div>

<script>
'use strict';

  // Immagini funghi
  const WEB_IMG = 'data:image/png;base64,';

  const WITCH_IMG = 'data:image/png;base64,';

  const BOMBER_IMG = 'data:image/png;base64,';

  const SCARED_IMGS = {
    green: 'data:image/png;base64,',
    orange: 'data:image/png;base64,',
    yellow: 'data:image/png;base64,',
    purple: 'data:image/png;base64,',
    blue: 'data:image/png;base64,',
    red: 'data:image/png;base64,',
  };

  const BOMB_IMGS = {
    cross: 'data:image/png;base64,',
    h: 'data:image/png;base64,',
    v: 'data:image/png;base64,',
  };

  const PETRIFIED_IMG = 'data:image/png;base64,';

  const SPIDER_IMGS = {
    4: 'data:image/png;base64,',
    2: 'data:image/png;base64,',
    3: 'data:image/png;base64,',
    1: 'data:image/png;base64,',
  };

  const MUSHROOM_IMGS = {
    green: 'data:image/png;base64,',
    orange: 'data:image/png;base64,',
    purple: 'data:image/png;base64,',
            red: 'data:image/png;base64,',
    yellow: 'data:image/png;base64,',
            blue: 'data:image/png;base64,',
  };


// ═══════════════════════════════════════════════════════
// COSTANTI
// ═══════════════════════════════════════════════════════
const ROWS = 6, COLS = 6;
const SPIDER_EVERY = 2;  // ragno ogni N tap
const ANIM_MS    = 200;
const CASCADE_MS = 260;

const COLORS = {
  red:    { bg: '#e74c3c', border: '#c0392b' },
  yellow: { bg: '#f1c40f', border: '#d4ac0d' },
  blue:   { bg: '#3498db', border: '#2980b9' },
  green:  { bg: '#2ecc71', border: '#27ae60' },
  orange: { bg: '#e67e22', border: '#ca6f1e' },
  purple: { bg: '#9b59b6', border: '#8e44ad' },
};
const COLOR_NAMES = Object.keys(COLORS);

// Soglie ragno
const SPIDER_THRESHOLDS = [
  { min: 2000, level: 4 },
  { min: 1500, level: 3 },
  { min: 500,  level: 2 },
  { min: 0,    level: 1 },
];

// ═══════════════════════════════════════════════════════
// STATO
// ═══════════════════════════════════════════════════════
let grid        = [];
let queue       = [];
let reserve     = null;
let score       = 0;
let tapCount    = 0;   // conta i tap, ogni SPIDER_EVERY → ragno
let gameOver    = false;
let busy        = false;
let cascading   = 0;
let needSpiderMove = false;
let needSpawn      = false;
let spiderSeq   = 0;

// ═══════════════════════════════════════════════════════
// CELLA
// ═══════════════════════════════════════════════════════
function mkEmptyCell() {
  return { color: null, bomb: null, spider: 0, spiderId: 0, web: false, black: false, empty: true };
}

function mkCell(color) {
  return {
    color:    color || rndColor(),
    bomb:     null,
    spider:   0,
    spiderId: 0,
    web:      false,
    black:    false,
    empty:    false,
  };
}

// ═══════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════
function rndColor()  { return COLOR_NAMES[Math.floor(Math.random() * COLOR_NAMES.length)]; }
function rndToken() {
  const r = Math.random();
  if (r < 1/7)       return 'witch';
  if (r < 2/7)       return 'bomber';
  return rndColor();
}
function el(id)       { return document.getElementById(id); }
function cellEl(r, c) { return document.querySelector(`.cell[data-r="${r}"][data-c="${c}"]`); }

let feedbackTimer = null;
function feedback(msg, color, ms) {
  clearTimeout(feedbackTimer);
  const fb = el('feedback');
  fb.textContent = msg;
  fb.style.color = color || '#888';
  if (ms) feedbackTimer = setTimeout(() => { fb.textContent = '; fb.style.color = '; }, ms);
}

// ═══════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════
function renderCell(r, c) {
  const d   = grid[r][c];
  const dom = cellEl(r, c);
  if (!dom) return;

  // Reset classi e stili
  dom.className  = 'cell';
  dom.innerHTML  = '';
  dom.style.cssText = '';

  // Cella vuota permanente (mangiata dal bruco)
  if (d.empty) {
    dom.style.background  = 'rgba(0,0,0,0.4)';
    dom.style.borderColor = 'rgba(0,0,0,0.2)';
    dom.classList.add('blocked');
    return;
  }

  // Cella nera — fungo pietrificato
  if (d.black && !d.spider) {
    dom.style.background  = 'transparent';
    dom.style.borderColor = 'transparent';
    const m = document.createElement('div');
    m.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center 55%;background-size:90%;pointer-events:none;';
    m.style.backgroundImage = `url(${PETRIFIED_IMG})`;
    dom.appendChild(m);
    dom.classList.add('blocked');
    return;
  }

  // Colore base + immagine fungo se disponibile
  const col = COLORS[d.color];
  // Se c'è una bomba con immagine, sfondo trasparente
  if (d.bomb && BOMB_IMGS[d.bomb]) {
    dom.style.background  = 'transparent';
    dom.style.borderColor = 'transparent';
  } else {
    dom.style.background  = col.bg;
    dom.style.borderColor = col.border;
  }

  if (MUSHROOM_IMGS[d.color] && !( d.bomb && BOMB_IMGS[d.bomb] )) {
    dom.style.background  = 'transparent';
    dom.style.borderColor = 'transparent';

    const m = document.createElement('div');
    m.className = 'mushroom';
    // Usa immagine scared se c'è ragno o ragnatela
    const scaredImg = (d.spider || d.web) && SCARED_IMGS[d.color];
    m.style.backgroundImage = `url(${scaredImg || MUSHROOM_IMGS[d.color]})`;
    if (d.color === 'red')    m.classList.add('idle-red');
    if (d.color === 'yellow') m.classList.add('idle-yellow');
    if (d.color === 'blue')   m.classList.add('idle-blue');
    if (d.color === 'green')  m.classList.add('idle-green');
    if (d.color === 'orange') m.classList.add('idle-orange');
    if (d.color === 'purple') m.classList.add('idle-purple');
    dom.appendChild(m);
    // Spawn solo se richiesto esplicitamente tramite classe sulla cella
    if (dom.dataset.spawn === '1') {
      dom.dataset.spawn = '0';
      void m.offsetWidth;
      m.classList.add('spawning');
      setTimeout(() => m.classList.remove('spawning'), 400);
    }
    if (d.spider) m.classList.add('scared');
    if (d.web) m.style.animationPlayState = 'paused';
  }

  // Bomba
  if (d.bomb) {
    const bOverlay = document.createElement('div');
    const bImg = BOMB_IMGS[d.bomb];
    if (bImg) {
      bOverlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center;background-size:95%;pointer-events:none;z-index:4;';
      bOverlay.style.backgroundImage = `url(${bImg})`;
    } else {
      bOverlay.style.cssText = 'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;pointer-events:none;z-index:4;';
      bOverlay.textContent = d.bomb === 'h' ? '↔' : d.bomb === 'v' ? '↕' : '✛';
    }
    dom.appendChild(bOverlay);
  }

  // Ragnatela: overlay sopra al fungo
  if (d.web) {
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:absolute;inset:0;background-repeat:no-repeat;background-position:center;background-size:100%;z-index:3;pointer-events:none;';
    overlay.style.backgroundImage = `url(${WEB_IMG})`;
    dom.appendChild(overlay);
    dom.classList.add('blocked');
    return;
  }

  // Ragno
  if (d.spider) {
    const overlay = document.createElement('div');
    const spiderImg = SPIDER_IMGS[d.spider];
    if (spiderImg) {
      overlay.style.cssText = 'position:absolute;inset:0;background-repeat:no-repeat;background-position:center;background-size:90%;z-index:3;pointer-events:none;';
      overlay.style.backgroundImage = `url(${spiderImg})`;
    } else {
      overlay.style.cssText = 'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;z-index:3;';
      overlay.textContent = d.spiderId + '-' + d.spider;
    }
    dom.appendChild(overlay);
    dom.classList.add('blocked');
  }
}

function renderAllCells() {
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++)
      renderCell(r, c);
}

function setMushroomBg(dom, color) {
  if (MUSHROOM_IMGS[color]) {
    dom.style.background    = 'transparent';
    dom.style.borderColor   = 'transparent';
    dom.innerHTML = '';
    const m = document.createElement('div');
    m.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center 55%;background-size:90%;pointer-events:none;';
    m.style.backgroundImage = `url(${MUSHROOM_IMGS[color]})`;
    dom.appendChild(m);
  } else {
    const col = COLORS[color];
    dom.style.background  = col.bg;
    dom.style.borderColor = col.border;
    dom.innerHTML = '';
  }
}

function renderToken(dom, token) {
  let img = null;
  if (token === 'witch')  img = WITCH_IMG;
  if (token === 'bomber') img = BOMBER_IMG;
  if (img) {
    dom.style.background  = 'transparent';
    dom.style.borderColor = 'transparent';
    dom.innerHTML = '';
    const m = document.createElement('div');
    m.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;background-repeat:no-repeat;background-position:center;background-size:90%;pointer-events:none;';
    m.style.backgroundImage = `url(${img})`;
    dom.appendChild(m);
  } else {
    setMushroomBg(dom, token);
  }
}

function renderQueue() {
  for (let i = 0; i < 3; i++) renderToken(el('q' + i), queue[i]);
}

function renderReserve() {
  const d = el('reserve');
  if (reserve) {
    renderToken(d, reserve);
    d.classList.add('filled');
  } else {
    d.style.background  = '#111';
    d.style.borderColor = '';
    d.innerHTML         = 'vuota';
    d.classList.remove('filled');
  }
}

function renderCountdown() {
  const remaining = SPIDER_EVERY - (tapCount % SPIDER_EVERY);
  const cd = el('spider-countdown');
  if (!cd) return;
  cd.textContent = remaining;
  // Pulse quando è a 1
  if (remaining === 1) {
    cd.classList.remove('pulse');
    void cd.offsetWidth;
    cd.classList.add('pulse');
  }
}

function animate(r, c, cls, ms) {
  const dom = cellEl(r, c);
  if (!dom) return;
  dom.classList.remove(cls);
  void dom.offsetWidth; // reflow
  dom.classList.add(cls);
  setTimeout(() => dom.classList.remove(cls), ms);
}

// ═══════════════════════════════════════════════════════
// MATCH DETECTION
// ═══════════════════════════════════════════════════════
// Cella partecipa al match se non è nera e non è bomba
// Ragni e ragnatele partecipano usando il colore sotto
function canMatch(r, c) {
  const d = grid[r][c];
  return !d.black && !d.bomb && !d.empty;
}

function findMatches() {
  const runs = [];

  // Orizzontali
  for (let r = 0; r < ROWS; r++) {
    let s = 0;
    for (let c = 1; c <= COLS; c++) {
      const cont = c < COLS
        && canMatch(r, c) && canMatch(r, c - 1)
        && grid[r][c].color === grid[r][c - 1].color;
      if (!cont) {
        if (c - s >= 3 && canMatch(r, s))
          runs.push({ cells: Array.from({length: c - s}, (_, i) => ({r, c: s + i})), dir: 'h' });
        s = c;
      }
    }
  }

  // Verticali
  for (let c = 0; c < COLS; c++) {
    let s = 0;
    for (let r = 1; r <= ROWS; r++) {
      const cont = r < ROWS
        && canMatch(r, c) && canMatch(r - 1, c)
        && grid[r][c].color === grid[r - 1][c].color;
      if (!cont) {
        if (r - s >= 3 && canMatch(s, c))
          runs.push({ cells: Array.from({length: r - s}, (_, i) => ({r: s + i, c})), dir: 'v' });
        s = r;
      }
    }
  }

  if (!runs.length) return [];

  // Merge run che condividono celle → T/croce
  const cellToRun = {};
  runs.forEach((run, idx) =>
    run.cells.forEach(({r, c}) => {
      const k = r + ',' + c;
      (cellToRun[k] = cellToRun[k] || []).push(idx);
    })
  );

  const used = new Set(), merged = [];
  runs.forEach((run, idx) => {
    if (used.has(idx)) return;
    const group = new Set([idx]);
    run.cells.forEach(({r, c}) =>
      (cellToRun[r + ',' + c] || []).forEach(j => group.add(j))
    );
    group.forEach(j => used.add(j));

    const allCells = new Map();
    const dirs     = new Set();
    group.forEach(j => {
      runs[j].cells.forEach(cell => allCells.set(cell.r + ',' + cell.c, cell));
      dirs.add(runs[j].dir);
    });

    const cells = [...allCells.values()];
    const type  = dirs.size > 1 ? 'cross'
                : cells.length > 3 ? runs[[...group][0]].dir
                : 'none';
    merged.push({ cells, type });
  });

  return merged;
}

// Tipo bomba generata dal match
function bombType(match) {
  if (match.type === 'cross')                       return 'cross';
  if (match.type === 'h' && match.cells.length >= 4) return 'h';
  if (match.type === 'v' && match.cells.length >= 4) return 'v';
  return null;
}

// ═══════════════════════════════════════════════════════
// SPAWN / CASCATA
// ═══════════════════════════════════════════════════════
function spawnCells(keys, bombPlacements) {
  const played = new Set();
  keys.forEach(key => {
    const [r, c] = key.split(',').map(Number);
    if (grid[r][c].empty) return; // mai sovrascrivere celle vuote permanenti
    grid[r][c] = mkCell();
    const color = grid[r][c].color;
    const dom = cellEl(r, c);
    if (dom) dom.dataset.spawn = '1';
    renderCell(r, c);
    if (!played.has(color)) { playMatchSound(color); played.add(color); }
  });
  bombPlacements.forEach(({r, c, type, color}) => {
    grid[r][c] = mkCell(color);
    grid[r][c].bomb = type;
    renderCell(r, c);
  });
}

function resolveBoard() {
  const matches = findMatches();
  if (!matches.length) {
    // Fine cascata: esegui moveSpiders se schedulato
    tryMoveSpiders();
    return;
  }

  cascading++;

  const toSpawn = new Set();
  const bombs   = [];

  matches.forEach(match => {
    const bt = bombType(match);
    match.cells.forEach(({r, c}) => {
      toSpawn.add(r + ',' + c);
      animate(r, c, 'anim-match', ANIM_MS);
    });
    if (bt) {
      const mid = match.cells[Math.floor(match.cells.length / 2)];
      bombs.push({r: mid.r, c: mid.c, type: bt, color: grid[mid.r][mid.c].color});
    }
  });

  setTimeout(() => {
    spawnCells(toSpawn, bombs);
    cascading--;
    setTimeout(resolveBoard, CASCADE_MS);
  }, ANIM_MS);
}

// ═══════════════════════════════════════════════════════
// APPLICA MATCH (mossa giocatore)
// ═══════════════════════════════════════════════════════
// Ritorna: false = nessun match | 'small' = solo tris | 'good' = 4+/T/croce
function applyMatches(matches, tapR, tapC) {
  if (!matches.length) return false;

  const toSpawn = new Set();
  const bombs   = [];

  matches.forEach(match => {
    const bt = bombType(match);
    match.cells.forEach(({r, c}) => {
      toSpawn.add(r + ',' + c);
      animate(r, c, 'anim-match', ANIM_MS);
    });
    if (bt) {
      const inMatch = tapR !== undefined
        && match.cells.some(d => d.r === tapR && d.c === tapC);
      const pos = inMatch
        ? {r: tapR, c: tapC}
        : match.cells[Math.floor(match.cells.length / 2)];
      bombs.push({r: pos.r, c: pos.c, type: bt, color: grid[pos.r][pos.c].color});
    }
  });

  score += toSpawn.size * 10;
  el('score-val').textContent = score;

  // Suono match — usa il colore della prima cella del primo match
  const firstColor = matches[0].cells[0];
  playMatchSound(grid[firstColor.r][firstColor.c].color);

  if (bombs.length) {
    feedback(bombs.map(b =>
      b.type === 'cross' ? '✛ Croce!' : b.type === 'h' ? '↔ Riga!' : '↕ Col.!'
    ).join(' '), '#ffd700', 1500);
  } else {
    feedback('+' + toSpawn.size * 10, '#aaa', 1200);
  }

  cascading++;
  setTimeout(() => {
    spawnCells(toSpawn, bombs);
    cascading--;
    setTimeout(resolveBoard, CASCADE_MS);
  }, ANIM_MS);

  const hasGood = matches.some(m => m.type !== 'none');

  // Notifica missioni
  matches.forEach(match => {
    const color = match.cells[0] ? grid[match.cells[0].r]?.[match.cells[0].c]?.color : null;
    // Celle eliminate per colore
    const colorCount = {};
    match.cells.forEach(({r, c}) => {
      const col = grid[r]?.[c]?.color;
      if (col) colorCount[col] = (colorCount[col] || 0) + 1;
    });
    Object.entries(colorCount).forEach(([col, amt]) =>
      addPowerCharge(col, amt)
    );
    // Bomba creata
    const bt = bombType(match);
    
  });

  return hasGood ? 'good' : 'small';
}

// ═══════════════════════════════════════════════════════
// BOMBE
// ═══════════════════════════════════════════════════════
function explodeBomb(r, c, exploded) {
  if (!exploded) exploded = new Set();
  const key = r + ',' + c;
  if (exploded.has(key)) return;
  exploded.add(key);

  const bt = grid[r][c].bomb;
  if (!bt) return;

  // Calcola celle colpite (escludi celle empty permanenti)
  const hit = new Set();
  if (bt === 'h' || bt === 'cross') for (let cc = 0; cc < COLS; cc++) { if (!grid[r][cc].empty) hit.add(r + ',' + cc); }
  if (bt === 'v' || bt === 'cross') for (let rr = 0; rr < ROWS; rr++) { if (!grid[rr][c].empty) hit.add(rr + ',' + c); }

  // Bombe a catena (prima di sovrascrivere)
  const chain = [];
  hit.forEach(k => {
    const [rr, cc] = k.split(',').map(Number);
    if ((rr !== r || cc !== c) && grid[rr][cc].bomb && !exploded.has(k))
      chain.push({r: rr, c: cc});
  });

  // Elimina speciali nelle celle colpite (bomba = tutto)
  hit.forEach(k => {
    const [rr, cc] = k.split(',').map(Number);
    const d = grid[rr][cc];
    if (d.spider) { d.spider = 0; d.spiderId = 0; }
    d.web = false; d.black = false;
  });

  hit.forEach(k => {
    const [rr, cc] = k.split(',').map(Number);
    animate(rr, cc, 'anim-explode', ANIM_MS);
  });

  score += hit.size * 10;
  el('score-val').textContent = score;
  playBombSound(bt);

  const label = bt === 'cross' ? '✛ Croce' : bt === 'h' ? '↔ Riga' : '↕ Col.';
  feedback(label + (chain.length ? ' 💥 Catena!' : '! +' + hit.size * 10), '#ffd700', 1500);

  chain.forEach(({r: rr, c: cc}) => explodeBomb(rr, cc, exploded));

  cascading++;
  setTimeout(() => {
    // Notifica missioni per celle eliminate
    hit.forEach(k => {
      const [rr, cc] = k.split(',').map(Number);
      const col = grid[rr][cc]?.color;
      if (col) addPowerCharge(col, 1);
    });
    spawnCells(hit, []);
    cascading--;
    setTimeout(resolveBoard, CASCADE_MS);
  }, ANIM_MS);
}

// ═══════════════════════════════════════════════════════
// RAGNI
// ═══════════════════════════════════════════════════════
function currentSpiderLevel() {
  for (const {min, level} of SPIDER_THRESHOLDS)
    if (score >= min) return level;
  return 1;
}

function freeCells() {
  const free = [];
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++) {
      const d = grid[r][c];
      if (!d.spider && !d.web && !d.black && !d.bomb && !d.empty) free.push({r, c});
    }
  return free;
}

function spawnSpider() {
  const lvl  = currentSpiderLevel();
  const free = freeCells();
  if (!free.length) { triggerGameOver(); return; }

  const pos = free[Math.floor(Math.random() * free.length)];

  {
    spiderSeq++;
    grid[pos.r][pos.c].spider   = lvl;
    grid[pos.r][pos.c].spiderId = spiderSeq;
    renderCell(pos.r, pos.c);
    const msg = lvl === 3 ? '💀 Ragno nero!' : lvl === 2 ? '🕷 Ragno velenoso!' : '🕷 Ragno!';
    feedback(msg, '#e74c3c', 1800);
  }

  checkStalemate();
  if (freeCells().length === 0) triggerGameOver();
}

function scheduleMoveSpiders() {
  needSpiderMove = true;
  tryMoveSpiders();
}

function tryMoveSpiders() {
  if (cascading > 0 || !needSpiderMove) return;
  needSpiderMove = false;
  moveSpiders();
  if (needSpawn) { needSpawn = false; spawnSpider(); }
  busy = false;
}

function moveSpiders() {
  // Raccogli ragni dalla griglia (fonte di verità)
  const spiders = [];
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++)
      if (grid[r][c].spider)
        spiders.push({r, c, lvl: grid[r][c].spider, sid: grid[r][c].spiderId});

  if (!spiders.length) return;

  // Fase 1: rimuovi ragni e lascia tracce
  spiders.forEach(({r, c, lvl}) => {
    grid[r][c].spider   = 0;
    grid[r][c].spiderId = 0;
    if (lvl === 2) grid[r][c].web   = true;
    if (lvl === 3) grid[r][c].black = true;
    if (lvl === 4) grid[r][c] = mkEmptyCell(); // bruco lascia cella vuota
  });

  // Fase 2: scegli destinazioni — il bruco (lvl4) non viene riposizionato
  const taken = new Set();
  spiders.forEach(({r, c, lvl, sid}) => {
    if (lvl === 4) return; // bruco scompare
    const free = [];
    for (let rr = 0; rr < ROWS; rr++)
      for (let cc = 0; cc < COLS; cc++) {
        const k = rr + ',' + cc;
        const d = grid[rr][cc];
        if (!d.web && !d.black && !d.bomb && !d.spider && !d.empty && !taken.has(k))
          free.push({r: rr, c: cc});
      }
    if (!free.length) return;
    const dest = free[Math.floor(Math.random() * free.length)];
    taken.add(dest.r + ',' + dest.c);
    grid[dest.r][dest.c].spider      = lvl;
    grid[dest.r][dest.c].spiderId    = sid;
  });

  renderAllCells();

  if (freeCells().length === 0) triggerGameOver();
}

