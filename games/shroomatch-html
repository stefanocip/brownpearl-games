// ═══════════════════════════════════════════════════════
// POWER BARS
// ═══════════════════════════════════════════════════════
const POWER_MAX = 20;
const POWER_COLORS = ['red','yellow','blue','green','orange','purple'];
const POWER_COLORS_IT = { red:'Rossi', yellow:'Gialli', blue:'Blu', green:'Verdi', orange:'Arancioni', purple:'Viola' };
const POWER_BAR_COLORS = {
  red: '#e74c3c', yellow: '#f1c40f', blue: '#3498db',
  green: '#2ecc71', orange: '#e67e22', purple: '#9b59b6'
};

let powerCharge = { red:0, yellow:0, blue:0, green:0, orange:0, purple:0 };

function buildPowerBarsDOM() {
  const wrap = el('power-bars');
  wrap.innerHTML = '';
  POWER_COLORS.forEach(color => {
    const bar = document.createElement('div');
    bar.className = 'power-bar';
    bar.id = 'pb-' + color;
    bar.innerHTML = `
      <div class="power-bar-track">
        <div class="power-bar-fill" id="pbf-${color}" style="background:${POWER_BAR_COLORS[color]}"></div>
      </div>
      <div class="power-bar-label">${POWER_COLORS_IT[color]}</div>`;
    wrap.appendChild(bar);
  });
}

function addPowerCharge(color, amount) {
  if (!powerCharge.hasOwnProperty(color)) return;
  if (powerCharge[color] >= POWER_MAX) return; // già piena
  powerCharge[color] = Math.min(POWER_MAX, powerCharge[color] + amount);
  renderPowerBar(color);
  if (powerCharge[color] >= POWER_MAX) {
    setTimeout(() => activatePower(color), 300);
  }
}

function renderPowerBar(color) {
  const fill = el('pbf-' + color);
  const bar  = el('pb-' + color);
  if (!fill || !bar) return;
  const pct = (powerCharge[color] / POWER_MAX) * 100;
  fill.style.width = pct + '%';
  bar.classList.toggle('ready', powerCharge[color] >= POWER_MAX);
}

function renderAllPowerBars() {
  POWER_COLORS.forEach(renderPowerBar);
}

function activatePower(color) {
  powerCharge[color] = 0;
  renderPowerBar(color);
  feedback('⚡ ' + POWER_COLORS_IT[color].toUpperCase() + ' POWER!', POWER_BAR_COLORS[color], 2000);

  switch(color) {
    case 'red':    powerRed();    break;
    case 'yellow': powerYellow(); break;
    case 'blue':   powerBlue();   break;
    case 'green':  powerGreen();  break;
    case 'orange': powerOrange(); break;
    case 'purple': powerPurple(); break;
  }
}

// ── FLASH CELLE CON COLORE POWER ────────────────────────
function flashCells(cellSet, color, callback) {
  const hexColor = POWER_BAR_COLORS[color];
  cellSet.forEach(k => {
    const [r, c] = k.split(',').map(Number);
    const dom = cellEl(r, c);
    if (!dom) return;
    dom.style.setProperty('--flash-color', hexColor);
    dom.classList.add('power-flashing');
  });
  setTimeout(() => {
    cellSet.forEach(k => {
      const [r, c] = k.split(',').map(Number);
      const dom = cellEl(r, c);
      if (dom) dom.classList.remove('power-flashing');
    });
    if (callback) callback();
  }, 380);
}

// ROSSO — 2 esplosioni 3x3 casuali
function powerRed() {
  const free = [];
  for (let r = 1; r < ROWS-1; r++)
    for (let c = 1; c < COLS-1; c++)
      free.push({r, c});
  for (let i = 0; i < 2; i++) {
    if (!free.length) break;
    const idx = Math.floor(Math.random() * free.length);
    const {r, c} = free.splice(idx, 1)[0];
    const cells = new Set();
    for (let dr = -1; dr <= 1; dr++)
      for (let dc = -1; dc <= 1; dc++) {
        const r2 = r+dr, c2 = c+dc;
        if (r2>=0&&r2<ROWS&&c2>=0&&c2<COLS&&!grid[r2][c2].empty) cells.add(r2+','+c2);
      }
    flashCells(cells, 'red', () => {
      cells.forEach(k => { const [r2,c2]=k.split(',').map(Number); animate(r2,c2,'anim-explode',ANIM_MS); });
      cascading++;
      setTimeout(() => {
        cells.forEach(k => {
          const [r2,c2]=k.split(',').map(Number);
          grid[r2][c2].spider=0; grid[r2][c2].spiderId=0;
          grid[r2][c2].web=false; grid[r2][c2].black=false;
          if(!grid[r2][c2].empty){grid[r2][c2]=mkCell();}
          const d=cellEl(r2,c2); if(d){d.dataset.spawn='1';} renderCell(r2,c2);
        });
        cascading--;
        setTimeout(resolveBoard, CASCADE_MS);
      }, ANIM_MS);
    });
  }
}

// GIALLO — elimina righe 0,2,4 o 1,3,5 a caso
function powerYellow() {
  const set = Math.random() < 0.5 ? [0,2,4] : [1,3,5];
  const cells = new Set();
  set.forEach(r => { for (let c=0;c<COLS;c++) { if(!grid[r][c].empty) cells.add(r+','+c); } });
  flashCells(cells, 'yellow', () => {
    cells.forEach(k => { const [r,c]=k.split(',').map(Number); animate(r,c,'anim-explode',ANIM_MS); });
    cascading++;
    setTimeout(() => {
      cells.forEach(k => {
        const [r,c]=k.split(',').map(Number);
        grid[r][c].spider=0; grid[r][c].spiderId=0; grid[r][c].web=false; grid[r][c].black=false;
        if(!grid[r][c].empty){grid[r][c]=mkCell(); const d=cellEl(r,c); if(d){d.dataset.spawn='1';} renderCell(r,c);} else { renderCell(r,c); }
      });
      cascading--;
      setTimeout(resolveBoard, CASCADE_MS);
    }, ANIM_MS);
  });
}

// BLU — elimina cornice esterna + 2x2 centrale
function powerBlue() {
  const cells = new Set();
  for (let c=0;c<COLS;c++) { cells.add('0,'+c); cells.add((ROWS-1)+','+c); }
  for (let r=1;r<ROWS-1;r++) { cells.add(r+',0'); cells.add(r+','+(COLS-1)); }
  const cr=Math.floor(ROWS/2), cc=Math.floor(COLS/2);
  [[cr-1,cc-1],[cr-1,cc],[cr,cc-1],[cr,cc]].forEach(([r,c])=>cells.add(r+','+c));
  flashCells(cells, 'blue', () => {
    cells.forEach(k => { const [r,c]=k.split(',').map(Number); animate(r,c,'anim-explode',ANIM_MS); });
    cascading++;
    setTimeout(() => {
      cells.forEach(k => {
        const [r,c]=k.split(',').map(Number);
        grid[r][c].spider=0; grid[r][c].spiderId=0; grid[r][c].web=false; grid[r][c].black=false;
        if(!grid[r][c].empty){grid[r][c]=mkCell(); const d=cellEl(r,c); if(d){d.dataset.spawn='1';} renderCell(r,c);} else { renderCell(r,c); }
      });
      cascading--;
      setTimeout(resolveBoard, CASCADE_MS);
    }, ANIM_MS);
  });
}

function powerGreen() {
  const free = [];
  for (let r=0;r<ROWS;r++)
    for (let c=0;c<COLS;c++)
      if (!grid[r][c].bomb && !grid[r][c].spider && !grid[r][c].web && !grid[r][c].black)
        free.push({r,c});
  const chosen = new Set();
  for (let i=0;i<3;i++) {
    if (!free.length) break;
    const idx = Math.floor(Math.random()*free.length);
    const {r,c} = free.splice(idx,1)[0];
    chosen.add(r+','+c);
  }
  flashCells(chosen, 'green', () => {
    chosen.forEach(k => {
      const [r,c] = k.split(',').map(Number);
      grid[r][c].bomb = 'cross';
      renderCell(r,c);
    });
  });
}

function powerPurple() {
  const cells = new Set();
  for (let r=0;r<ROWS;r++)
    for (let c=0;c<COLS;c++)
      if (grid[r][c].spider || grid[r][c].web) cells.add(r+','+c);
  if (cells.size === 0) return;
  flashCells(cells, 'purple', () => {
    cells.forEach(k => {
      const [r,c] = k.split(',').map(Number);
      grid[r][c].spider=0; grid[r][c].spiderId=0; grid[r][c].web=false;
      animate(r,c,'anim-match',ANIM_MS);
      renderCell(r,c);
